# Gemini API Key (required for eval runs)
GEMINI_API_KEY=your_gemini_api_key_here
NOTION_API_KEY="your-key"
NOTION_TEST_DATABASE_ID="db-id"
NOTION_TEST_PAGE_ID="page-id"

# Freshsales CRM configuration
FRESHSALES_API_KEY="your-freshsales-key"
FRESHSALES_DOMAIN="your-freshsales-domain"
FRESHSALES_TEST_CONTACT_ID="contact-id"
FRESHSALES_TEST_ACCOUNT_ID="account-id"
FRESHSALES_TEST_DEAL_ID="deal-id"

pnpm run eval --server=notion
pnpm run eval --server=freshsales